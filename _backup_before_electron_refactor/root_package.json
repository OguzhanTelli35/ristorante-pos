{
  "name": "ristorante-pos",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready restaurant POS system",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build --workspaces",
    "typecheck": "tsc --noEmit --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf shared/dist backend/dist frontend/dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
